{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://neonpro.com/schemas/lgpd-automation.json",
  "title": "LGPD Automation Configuration",
  "description": "Schema para validação da configuração de automação LGPD do NeonPro",
  "type": "object",
  "required": ["automation", "schedules", "features", "notifications", "limits"],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Versão da configuração (semver)"
    },
    "description": {
      "type": "string",
      "description": "Descrição da configuração"
    },
    "automation": {
      "type": "object",
      "required": ["enabled"],
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Habilita/desabilita toda a automação"
        },
        "environment": {
          "type": "string",
          "enum": ["development", "staging", "production"],
          "default": "production"
        },
        "debug": {
          "type": "boolean",
          "default": false
        },
        "timezone": {
          "type": "string",
          "default": "America/Sao_Paulo",
          "description": "Fuso horário para agendamentos"
        }
      }
    },
    "schedules": {
      "type": "object",
      "properties": {
        "full_automation": {
          "$ref": "#/definitions/schedule"
        },
        "consent_management": {
          "$ref": "#/definitions/schedule"
        },
        "data_subject_rights": {
          "$ref": "#/definitions/schedule"
        },
        "audit_reporting": {
          "$ref": "#/definitions/schedule"
        },
        "data_anonymization": {
          "$ref": "#/definitions/schedule"
        },
        "monitoring": {
          "$ref": "#/definitions/schedule"
        }
      }
    },
    "features": {
      "type": "object",
      "properties": {
        "consent_management": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "auto_renewal": { "type": "boolean" },
            "expiration_warning_days": { "type": "integer", "minimum": 1, "maximum": 365 },
            "batch_size": { "type": "integer", "minimum": 1, "maximum": 1000 },
            "parallel_processing": { "type": "boolean" }
          }
        },
        "data_subject_rights_processing": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "auto_processing": { "type": "boolean" },
            "response_deadline_days": { "type": "integer", "minimum": 1, "maximum": 30 },
            "batch_size": { "type": "integer", "minimum": 1, "maximum": 500 },
            "priority_queue": { "type": "boolean" }
          }
        },
        "audit_reporting": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "auto_generation": { "type": "boolean" },
            "retention_days": { "type": "integer", "minimum": 365, "maximum": 3650 },
            "include_metrics": { "type": "boolean" },
            "detailed_logs": { "type": "boolean" }
          }
        },
        "data_anonymization": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "auto_anonymization": { "type": "boolean" },
            "retention_days": { "type": "integer", "minimum": 365, "maximum": 3650 },
            "anonymization_method": {
              "type": "string",
              "enum": ["k_anonymity", "l_diversity", "t_closeness", "differential_privacy"]
            },
            "k_value": { "type": "integer", "minimum": 2, "maximum": 100 }
          }
        },
        "real_time_monitoring": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "alert_threshold": { "type": "number", "minimum": 0, "maximum": 1 },
            "monitoring_interval": { "type": "integer", "minimum": 60, "maximum": 3600 },
            "performance_tracking": { "type": "boolean" },
            "anomaly_detection": { "type": "boolean" }
          }
        },
        "intelligent_alerts": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "ai_powered": { "type": "boolean" },
            "severity_auto_assignment": { "type": "boolean" },
            "auto_resolution": { "type": "boolean" },
            "escalation_rules": { "type": "boolean" }
          }
        }
      }
    },
    "notifications": {
      "type": "object",
      "properties": {
        "email": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "smtp_host": { "type": "string" },
            "smtp_port": { "type": "integer", "minimum": 1, "maximum": 65535 },
            "smtp_secure": { "type": "boolean" },
            "smtp_user": { "type": "string" },
            "smtp_password": { "type": "string" },
            "from_address": { "type": "string", "format": "email" },
            "from_name": { "type": "string" },
            "recipients": {
              "type": "object",
              "properties": {
                "admins": { "type": "array", "items": { "type": "string", "format": "email" } },
                "managers": { "type": "array", "items": { "type": "string", "format": "email" } },
                "alerts": { "type": "array", "items": { "type": "string", "format": "email" } }
              }
            },
            "templates": {
              "type": "object",
              "properties": {
                "job_success": { "type": "string" },
                "job_failure": { "type": "string" },
                "compliance_alert": { "type": "string" },
                "weekly_report": { "type": "string" }
              }
            }
          }
        },
        "webhook": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "url": { "type": "string", "format": "uri" },
            "secret": { "type": "string" },
            "timeout": { "type": "integer", "minimum": 1, "maximum": 300 },
            "retry_attempts": { "type": "integer", "minimum": 0, "maximum": 10 },
            "events": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": [
                  "job.completed",
                  "job.failed",
                  "alert.created",
                  "alert.resolved",
                  "compliance.score_changed"
                ]
              }
            },
            "headers": {
              "type": "object",
              "additionalProperties": { "type": "string" }
            }
          }
        },
        "slack": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "webhook_url": { "type": "string", "format": "uri" },
            "channel": { "type": "string" },
            "username": { "type": "string" },
            "icon_emoji": { "type": "string" },
            "mention_on_critical": { "type": "boolean" },
            "mention_users": { "type": "array", "items": { "type": "string" } }
          }
        }
      }
    },
    "limits": {
      "type": "object",
      "required": ["performance"],
      "properties": {
        "performance": {
          "type": "object",
          "required": ["max_concurrent_jobs", "job_timeout_minutes", "max_retry_attempts", "batch_size"],
          "properties": {
            "max_concurrent_jobs": { "type": "integer", "minimum": 1, "maximum": 10 },
            "job_timeout_minutes": { "type": "integer", "minimum": 5, "maximum": 120 },
            "max_retry_attempts": { "type": "integer", "minimum": 1, "maximum": 5 },
            "batch_size": { "type": "integer", "minimum": 10, "maximum": 1000 },
            "memory_limit_mb": { "type": "integer", "minimum": 128, "maximum": 2048 },
            "cpu_limit_percent": { "type": "integer", "minimum": 10, "maximum": 100 }
          }
        },
        "rate_limiting": {
          "type": "object",
          "properties": {
            "api_requests_per_minute": { "type": "integer", "minimum": 100, "maximum": 10000 },
            "database_queries_per_minute": { "type": "integer", "minimum": 1000, "maximum": 50000 },
            "email_notifications_per_hour": { "type": "integer", "minimum": 10, "maximum": 1000 },
            "webhook_calls_per_minute": { "type": "integer", "minimum": 10, "maximum": 1000 }
          }
        },
        "storage": {
          "type": "object",
          "properties": {
            "max_log_size_mb": { "type": "integer", "minimum": 10, "maximum": 1000 },
            "max_audit_records": { "type": "integer", "minimum": 100000, "maximum": 10000000 },
            "log_retention_days": { "type": "integer", "minimum": 30, "maximum": 365 },
            "temp_file_cleanup_hours": { "type": "integer", "minimum": 1, "maximum": 168 }
          }
        }
      }
    },
    "security": {
      "type": "object",
      "properties": {
        "encryption": {
          "type": "object",
          "properties": {
            "algorithm": {
              "type": "string",
              "enum": ["AES-256-GCM", "AES-256-CBC", "ChaCha20-Poly1305"]
            },
            "key_rotation_days": { "type": "integer", "minimum": 30, "maximum": 365 },
            "encrypt_logs": { "type": "boolean" },
            "encrypt_temp_files": { "type": "boolean" }
          }
        },
        "access_control": {
          "type": "object",
          "properties": {
            "require_2fa": { "type": "boolean" },
            "session_timeout_minutes": { "type": "integer", "minimum": 30, "maximum": 1440 },
            "max_failed_attempts": { "type": "integer", "minimum": 3, "maximum": 10 },
            "lockout_duration_minutes": { "type": "integer", "minimum": 5, "maximum": 1440 }
          }
        },
        "audit": {
          "type": "object",
          "properties": {
            "log_all_actions": { "type": "boolean" },
            "include_ip_address": { "type": "boolean" },
            "include_user_agent": { "type": "boolean" },
            "hash_sensitive_data": { "type": "boolean" }
          }
        }
      }
    },
    "monitoring": {
      "type": "object",
      "properties": {
        "metrics": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "collection_interval": { "type": "integer", "minimum": 60, "maximum": 3600 },
            "retention_days": { "type": "integer", "minimum": 30, "maximum": 1095 },
            "aggregation_levels": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": ["hourly", "daily", "weekly", "monthly"]
              }
            }
          }
        },
        "health_checks": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "interval_seconds": { "type": "integer", "minimum": 30, "maximum": 300 },
            "timeout_seconds": { "type": "integer", "minimum": 5, "maximum": 60 },
            "failure_threshold": { "type": "integer", "minimum": 1, "maximum": 10 }
          }
        },
        "alerting": {
          "type": "object",
          "properties": {
            "compliance_score_threshold": { "type": "integer", "minimum": 50, "maximum": 100 },
            "job_failure_threshold": { "type": "integer", "minimum": 1, "maximum": 10 },
            "response_time_threshold_ms": { "type": "integer", "minimum": 1000, "maximum": 30000 },
            "error_rate_threshold_percent": { "type": "integer", "minimum": 1, "maximum": 50 }
          }
        }
      }
    },
    "compliance": {
      "type": "object",
      "properties": {
        "lgpd": {
          "type": "object",
          "properties": {
            "consent_expiration_days": { "type": "integer", "minimum": 180, "maximum": 1095 },
            "data_retention_days": { "type": "integer", "minimum": 365, "maximum": 3650 },
            "anonymization_delay_days": { "type": "integer", "minimum": 0, "maximum": 90 },
            "audit_trail_retention_days": { "type": "integer", "minimum": 1095, "maximum": 3650 },
            "incident_response_hours": { "type": "integer", "minimum": 24, "maximum": 168 }
          }
        },
        "scoring": {
          "type": "object",
          "properties": {
            "weights": {
              "type": "object",
              "properties": {
                "consent_compliance": { "type": "integer", "minimum": 0, "maximum": 100 },
                "audit_coverage": { "type": "integer", "minimum": 0, "maximum": 100 },
                "alert_resolution": { "type": "integer", "minimum": 0, "maximum": 100 },
                "request_processing": { "type": "integer", "minimum": 0, "maximum": 100 }
              }
            },
            "thresholds": {
              "type": "object",
              "properties": {
                "excellent": { "type": "integer", "minimum": 90, "maximum": 100 },
                "good": { "type": "integer", "minimum": 80, "maximum": 95 },
                "acceptable": { "type": "integer", "minimum": 60, "maximum": 85 },
                "poor": { "type": "integer", "minimum": 0, "maximum": 70 }
              }
            }
          }
        }
      }
    },
    "integration": {
      "type": "object",
      "properties": {
        "supabase": {
          "type": "object",
          "properties": {
            "connection_pool_size": { "type": "integer", "minimum": 5, "maximum": 50 },
            "query_timeout_seconds": { "type": "integer", "minimum": 10, "maximum": 120 },
            "retry_attempts": { "type": "integer", "minimum": 1, "maximum": 5 },
            "batch_insert_size": { "type": "integer", "minimum": 100, "maximum": 5000 }
          }
        },
        "external_apis": {
          "type": "object",
          "properties": {
            "timeout_seconds": { "type": "integer", "minimum": 10, "maximum": 120 },
            "retry_attempts": { "type": "integer", "minimum": 1, "maximum": 5 },
            "rate_limit_per_minute": { "type": "integer", "minimum": 10, "maximum": 1000 }
          }
        }
      }
    },
    "development": {
      "type": "object",
      "properties": {
        "debug_mode": { "type": "boolean" },
        "verbose_logging": { "type": "boolean" },
        "mock_external_services": { "type": "boolean" },
        "test_data_generation": { "type": "boolean" },
        "performance_profiling": { "type": "boolean" }
      }
    }
  },
  "definitions": {
    "schedule": {
      "type": "object",
      "required": ["enabled", "cron_expression"],
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Habilita/desabilita este agendamento"
        },
        "cron_expression": {
          "type": "string",
          "pattern": "^\\s*($|#|\\w+\\s*=|(\\?|\\*|(?:[0-5]?\\d)(?:(?:-|\\/|\\,)(?:[0-5]?\\d))?(?:,(?:[0-5]?\\d)(?:(?:-|\\/|\\,)(?:[0-5]?\\d))?)*)\\s+(\\?|\\*|(?:[0-5]?\\d)(?:(?:-|\\/|\\,)(?:[0-5]?\\d))?(?:,(?:[0-5]?\\d)(?:(?:-|\\/|\\,)(?:[0-5]?\\d))?)*)\\s+(\\?|\\*|(?:[01]?\\d|2[0-3])(?:(?:-|\\/|\\,)(?:[01]?\\d|2[0-3]))?(?:,(?:[01]?\\d|2[0-3])(?:(?:-|\\/|\\,)(?:[01]?\\d|2[0-3]))?)*)\\s+(\\?|\\*|(?:0?[1-9]|[12]\\d|3[01])(?:(?:-|\\/|\\,)(?:0?[1-9]|[12]\\d|3[01]))?(?:,(?:0?[1-9]|[12]\\d|3[01])(?:(?:-|\\/|\\,)(?:0?[1-9]|[12]\\d|3[01]))?)*)\\s+(\\?|\\*|(?:[1-9]|1[012])(?:(?:-|\\/|\\,)(?:[1-9]|1[012]))?(?:,(?:[1-9]|1[012])(?:(?:-|\\/|\\,)(?:[1-9]|1[012]))?)*)\\s+(\\?|\\*|(?:[0-6])(?:(?:-|\\/|\\,)(?:[0-6]))?(?:,(?:[0-6])(?:(?:-|\\/|\\,)(?:[0-6]))?)*))$",
          "description": "Expressão Cron válida (formato: minuto hora dia mês dia-da-semana)"
        },
        "description": {
          "type": "string",
          "description": "Descrição do agendamento"
        },
        "timezone": {
          "type": "string",
          "default": "America/Sao_Paulo",
          "description": "Fuso horário para este agendamento"
        },
        "max_execution_time": {
          "type": "integer",
          "minimum": 60,
          "maximum": 14400,
          "description": "Tempo máximo de execução em segundos"
        },
        "retry_on_failure": {
          "type": "boolean",
          "default": true,
          "description": "Tentar novamente em caso de falha"
        },
        "max_retries": {
          "type": "integer",
          "minimum": 0,
          "maximum": 5,
          "description": "Número máximo de tentativas"
        }
      }
    }
  }
}