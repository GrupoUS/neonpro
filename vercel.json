{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "pnpm build",
  "devCommand": "pnpm dev",
  "regions": ["gru1"],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Healthcare-Compliance",
          "value": "LGPD-ANVISA-CFM"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=31536000; includeSubDomains"
        }
      ]
    },
    {
      "source": "/api/patients/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, no-cache, must-revalidate"
        },
        {
          "key": "X-Patient-Data-Protection",
          "value": "LGPD-Compliant"
        }
      ]
    }
  ],
  "installCommand": "pnpm install",
  "framework": "nextjs",
  "regions": ["iad1", "gru1"],
  "functions": {
    "app/auth/popup-callback/route.ts": {
      "maxDuration": 30
    },
    "app/auth/callback/route.ts": {
      "maxDuration": 30
    },
    "app/api/cron/evaluate-alerts/route.ts": {
      "maxDuration": 60
    },
    "app/api/trigger/route.ts": {
      "maxDuration": 300,
      "memory": 1024,
      "runtime": "nodejs20.x"
    },
    "app/api/appointments/enhanced/route.ts": {
      "maxDuration": 30,
      "memory": 512
    },
    "app/api/monitoring/*/route.ts": {
      "maxDuration": 15,
      "memory": 256
    }
  },
  "crons": [
    {
      "path": "/api/cron/evaluate-alerts",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/cleanup-metrics",
      "schedule": "0 2 * * *"
    }
  ],
  "headers": [
    {
      "source": "/auth/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/health",
      "destination": "/api/health"
    },
    {
      "source": "/metrics",
      "destination": "/api/monitoring/performance"
    }
  ],
  "env": {
    "VERCEL_ENV": "production",
    "NODE_ENV": "production"
  }
}
