{
  "functions": {
    "app/auth/popup-callback/route.ts": {
      "maxDuration": 30
    },
    "app/auth/callback/route.ts": {
      "maxDuration": 30
    }
  },
  "headers": [
    {
      "source": "/auth/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    }
  ]
}
