# NEONPRO Environment Variables
# Generated by VIBECODE SYSTEM V4.0 - Architectural Optimization
# Copy this file to .env.local and fill in your actual values

# ===== DATABASE =====
# Supabase Postgres Database URL
DATABASE_URL="postgresql://postgres:[password]@db.[project].supabase.co:5432/postgres"

# ===== SUPABASE =====
# Supabase Project Configuration
NEXT_PUBLIC_SUPABASE_URL="https://[project].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-supabase-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"

# ===== AI INTEGRATION =====
# OpenAI API Configuration
OPENAI_API_KEY="sk-your-openai-api-key"
OPENAI_ORGANIZATION_ID="org-your-organization-id"

# Vercel AI SDK Configuration
AI_MODEL="gpt-4o-mini"
AI_MAX_TOKENS="1000"

# ===== AUTHENTICATION =====
# NextAuth.js Configuration
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-nextauth-secret"

# ===== EXTERNAL SERVICES =====
# Email Service (Resend)
RESEND_API_KEY="re_your-resend-api-key"

# File Storage
NEXT_PUBLIC_STORAGE_BUCKET="neonpro-storage"

# ===== DEVELOPMENT =====
# Development Environment
NODE_ENV="development"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ===== ANALYTICS =====
# Optional: Analytics Configuration
NEXT_PUBLIC_ANALYTICS_ID="your-analytics-id"

# ===== SECURITY =====
# CORS Configuration
ALLOWED_ORIGINS="http://localhost:3000,https://neonpro.vercel.app"

# Rate Limiting
UPSTASH_REDIS_REST_URL="your-upstash-redis-url"
UPSTASH_REDIS_REST_TOKEN="your-upstash-redis-token"
