# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# App Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=NeonPro

# WhatsApp Business API (Configuração obrigatória para produção)
WHATSAPP_API_KEY=your_whatsapp_business_api_key
WHATSAPP_PHONE_NUMBER=your_whatsapp_business_phone_number_id

# Configurações adicionais do WhatsApp
WHATSAPP_VERIFY_TOKEN=your_webhook_verify_token
WHATSAPP_WEBHOOK_SECRET=your_webhook_secret

# Email Service (Optional)
EMAIL_SERVICE_API_KEY=your_email_service_api_key
EMAIL_FROM=noreply@yourapp.com

# Analytics (Optional)
NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=your_google_analytics_id

# Sentry (Optional)
SENTRY_DSN=your_sentry_dsn
SENTRY_ORG=your_sentry_org
SENTRY_PROJECT=your_sentry_project

# Environment
NODE_ENV=development

# Production URLs (configurar para produção)
NEXT_PUBLIC_VERCEL_URL=your_vercel_app_url
NEXT_PUBLIC_PRODUCTION_URL=https://your-domain.com
