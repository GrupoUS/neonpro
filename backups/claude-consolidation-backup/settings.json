{
  "version": "6.0",
  "description": "NeonPro VIBECODE V6.0 Healthcare AI Framework - APEX Intelligent Hooks Configuration with Hub-and-Spoke Architecture",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": ".*",
        "description": "VoidBeast Intelligence - Autonomous complexity detection and Portuguese triggers",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/voidbeast-intelligence.sh \"$INPUT\""
          }
        ]
      },
      {
        "matcher": ".*file.*|.*create.*|.*write.*|.*read.*|.*patient.*|.*medical.*|.*healthcare.*",
        "description": "APEX MCP Enforcement V6.0 - Desktop Commander supremacy with healthcare zero tolerance",
        "hooks": [
          {
            "type": "command", 
            "command": "bash .claude/hooks/apex-mcp-enforcement.sh \"$INPUT\""
          }
        ]
      },
      {
        "matcher": ".*VIBECODE.*|.*Context Engineering.*|.*complexity.*|.*L1.*|.*L2.*|.*L3.*|.*L4.*",
        "description": "VIBECODE V6.0 Hub Orchestration - Intelligent complexity-based delegation",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/vibecode-hub-orchestration.sh \"$INPUT\""
          }
        ]
      },
      {
        "matcher": ".*lembre.*|.*continue.*|.*implementar.*|.*contexto.*|.*neonpro.*",
        "description": "Memory Bank V5.0 - Smart Portuguese triggers and context loading",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/memory-bank-activation.sh \"$INPUT\""
          }
        ]
      },
      {
        "matcher": ".*refactor.*|.*architect.*|.*compliance.*|.*patient.*|.*LGPD.*|.*ANVISA.*|.*CFM.*|.*complex.*|.*strategy.*",
        "description": "Dynamic Thinking V4.0 - Complexity-based thinking level auto-escalation",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/dynamic-thinking-escalation.sh \"$INPUT\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": ".*healthcare.*|.*patient.*|.*medical.*|.*LGPD.*|.*ANVISA.*|.*CFM.*",
        "description": "Healthcare Compliance Validation - LGPD/ANVISA/CFM automatic compliance check",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/healthcare-compliance.sh \"$OUTPUT\""
          }
        ]
      },
      {
        "matcher": ".*",
        "description": "Quality Enforcement - Ensure ≥9.8/10 healthcare quality standards",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/quality-enforcement.sh \"$OUTPUT\""
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": ".*",
        "description": "Pre-task Validation - Healthcare priority assessment and workflow preparation",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/pre-task-validation.sh \"$INPUT\""
          }
        ]
      }
    ]
  },
  "project_config": {
    "vibecode_version": "6.0",
    "architecture": "hub-and-spoke",
    "healthcare_focus": true,
    "quality_threshold": 9.8,
    "patient_safety_threshold": 9.9,
    "compliance_standards": ["LGPD", "ANVISA", "CFM"],
    "performance_targets": {
      "patient_data_access": "100ms",
      "context_loading": "85% improvement", 
      "mcp_optimization": "90% efficiency",
      "context_assembly": "200ms",
      "mcp_execution": "30s"
    },
    "hub_coordination": {
      "primary_hub": "CLAUDE.md",
      "specialized_spoke": "apex-developer.md",
      "delegation_levels": ["L1", "L2", "L3", "L4"],
      "context_engineering": "V3.0"
    }
  },
  "intelligent_routing": {
    "vibecode_v6_hub": {
      "enabled": true,
      "hub_and_spoke_architecture": true,
      "context_engineering_v3": true,
      "intelligent_delegation": true,
      "healthcare_specialization": true
    },
    "voidbeast_intelligence": {
      "enabled": true,
      "complexity_detection": true,
      "portuguese_triggers": true,
      "healthcare_priority": true,
      "delegation_matrix": ["L1", "L2", "L3", "L4"]
    },
    "apex_enforcement": {
      "enabled": true,
      "version": "6.0",
      "desktop_commander_mandatory": true,
      "zero_tolerance_policy": true,
      "context_engineering": true,
      "healthcare_zero_tolerance": true
    },
    "memory_bank": {
      "enabled": true,
      "version": "5.0",
      "smart_activation": true,
      "portuguese_triggers": true,
      "context_levels": 4,
      "healthcare_memory": true
    },
    "research_protocols": {
      "enabled": true,
      "mandatory_sequence": ["context7", "tavily", "exa", "sequential"],
      "consistency_threshold": 0.98,
      "quality_threshold": 9.8,
      "healthcare_research": true,
      "medical_validation": true
    }
  },
  "automation": {
    "hooks_enabled": true,
    "vibecode_v6_automation": true,
    "portuguese_support": true,
    "healthcare_automation": true,
    "quality_gates": true,
    "compliance_monitoring": true,
    "hub_orchestration": true,
    "context_engineering_automation": true,
    "intelligent_delegation": true
  },
  "vibecode_v6_status": {
    "system_authority": "Supreme Healthcare Orchestration Hub ACTIVE",
    "integration_level": "Context Engineering V3.0 + Hub-and-Spoke Architecture",
    "orchestration_scope": "L1-L4 intelligent delegation with healthcare specialization",
    "performance_optimization": "85%+ context reduction with quality preservation",
    "quality_enforcement": "≥9.8/10 healthcare | ≥9.9/10 patient safety",
    "healthcare_specialization": "Brazilian medical compliance with LGPD/ANVISA/CFM"
  }
}