# Ignore local development files
.env.local
.env.development
.env.test
.vscode/
.DS_Store

# Ignore build artifacts that shouldn't be deployed
.turbo/
node_modules/.cache/
*.tsbuildinfo

# Ignore large files and directories
public/large-assets/
docs/
__tests__/
coverage/

# Ignore Prisma migration files (use seed instead)
prisma/migrations/
prisma/dev.db*