# Trae AI Configuration for NeonPro
# Healthcare-focused aesthetic clinic management system

[project]
name = "NeonPro"
type = "healthcare-saas"
framework = "Next.js 15+"
backend = "Supabase"
deployment = "Vercel"

[rules]
project_rules = "docs/project_rules.md"
auto_load = true
priority = "high"

[context_engineering]
intelligent_loading = true
performance_optimization = true
context_assembly_timeout = 200
complexity_assessment_timeout = 5000
context_accuracy_target = 0.95

[healthcare_compliance]
lgpd_enabled = true
anvisa_enabled = true
cfm_enabled = true
audit_logging = true
data_encryption = true

[quality_gates]
code_coverage = 90
maintainability_index = 85
security_rating = "A"
accessibility_compliance = "WCAG_2_1_AA"

[tech_stack]
framework = "Next.js 15+"
backend = "Supabase"
deployment = "Vercel"
ui = "shadcn/ui + Tailwind CSS"
state_management = "Zustand + TanStack Query"
validation = "Zod + React Hook Form"

[monitoring]
performance_tracking = true
error_tracking = "Sentry"
compliance_monitoring = true
business_metrics = true

[paths]
docs = "docs/"
components = "components/"
api = "app/api/"
tests = "tests/"

[development]
auto_format = true
lint_on_save = true
type_check = true
security_scan = true

# Healthcare-specific settings
[healthcare]
patient_data_encryption = true
hipaa_compliance = false  # Brazilian clinic - LGPD applies
lgpd_compliance = true
anvisa_compliance = true
cfm_compliance = true
audit_trail = true
data_retention_policy = true

# Performance targets for healthcare applications
[performance]
page_load_target = 2000  # 2 seconds
api_response_target = 500  # 500ms
uptime_target = 99.9  # 99.9%
error_rate_target = 0.1  # 0.1%