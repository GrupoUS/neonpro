// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
  extensions = [uuid_ossp(map: "uuid-ossp")]
}

// 🚧 CORE MODELS FOR NEONPRO HEALTHCARE SYSTEM
// Based on Supabase introspection of 167+ tables

/// Healthcare professional profiles with RLS enabled
model Profile {
  id                     String    @id @db.Uuid
  email                  String?   @unique
  full_name              String?
  first_name             String?
  last_name              String?
  role                   String?   @default("professional")
  medical_license        String?
  department             String?
  professional_title     String?
  phone                  String?
  avatar_url             String?
  
  // Google integration
  google_provider_id     String?   @unique
  google_picture         String?
  google_verified_email  Boolean?  @default(false)
  profile_sync_status    String?   @default("pending")
  google_sync_enabled    Boolean?  @default(true)
  last_google_sync       DateTime? @db.Timestamptz(6)
  
  // LGPD compliance
  data_consent_given     Boolean?  @default(false)
  data_consent_date      DateTime? @db.Timestamptz(6)
  
  // Timestamps
  created_at             DateTime  @default(now()) @db.Timestamptz(6)
  updated_at             DateTime  @default(now()) @db.Timestamptz(6)
  
  // Relations
  patients_created           Patient[]       @relation("PatientCreatedBy")
  clinics_created            Clinic[]        @relation("ClinicCreatedBy")
  appointments_as_provider   Appointment[]   @relation("ProviderAppointments")
  appointments_created       Appointment[]   @relation("AppointmentCreatedBy")
  medical_records_as_provider MedicalRecord[] @relation("ProviderMedicalRecords")
  medical_records_created    MedicalRecord[] @relation("MedicalRecordCreatedBy")
  prescriptions_as_prescriber Prescription[] @relation("PrescriberPrescriptions")
  prescriptions_created      Prescription[]  @relation("PrescriptionCreatedBy")
  audit_logs                 AuditLog[]      @relation("UserAuditLogs")
  
  @@map("profiles")
}

/// Patient records with medical information
model Patient {
  id                     String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clinic_id              String    @db.Uuid
  full_name              String
  email                  String?
  phone                  String?
  birth_date             DateTime? @db.Date
  
  // Healthcare specific
  medical_record_number  String?   @unique
  emergency_contact      String?
  insurance_provider     String?
  
  // LGPD compliance
  data_consent_given     Boolean?  @default(false)
  data_consent_date      DateTime? @db.Timestamptz(6)
  
  // Metadata
  created_by             String    @db.Uuid
  updated_by             String?   @db.Uuid
  created_at             DateTime  @default(now()) @db.Timestamptz(6)
  updated_at             DateTime  @default(now()) @db.Timestamptz(6)
  
  // Relations
  clinic                 Clinic          @relation(fields: [clinic_id], references: [id])
  created_by_profile     Profile         @relation("PatientCreatedBy", fields: [created_by], references: [id])
  appointments           Appointment[]
  medical_records        MedicalRecord[]
  prescriptions          Prescription[]
  
  @@map("patients")
}

/// Clinic facilities management
model Clinic {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name              String
  address           String?
  phone             String?
  email             String?
  
  // Business information
  cnpj              String?   @unique
  license_number    String?
  
  // Compliance and settings
  is_active         Boolean?  @default(true)
  
  // Metadata
  created_by        String    @db.Uuid
  updated_by        String?   @db.Uuid
  created_at        DateTime  @default(now()) @db.Timestamptz(6)
  updated_at        DateTime  @default(now()) @db.Timestamptz(6)
  
  // Relations
  created_by_profile Profile         @relation("ClinicCreatedBy", fields: [created_by], references: [id])
  patients           Patient[]
  appointments       Appointment[]
  medical_records    MedicalRecord[]
  prescriptions      Prescription[]
  audit_logs         AuditLog[]
  
  @@map("clinics")
}

/// Medical appointments scheduling
model Appointment {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clinic_id         String    @db.Uuid
  patient_id        String    @db.Uuid
  provider_id       String    @db.Uuid
  
  // Appointment details
  scheduled_at      DateTime  @db.Timestamptz(6)
  duration_minutes  Int       @default(30)
  appointment_type  String    // consultation, emergency, follow_up, etc.
  status           String    @default("scheduled") // scheduled, confirmed, cancelled, completed, no_show
  
  // Medical information
  chief_complaint   String?
  notes            String?
  diagnosis        String?
  treatment_plan   String?
  
  // Compliance and audit
  cancellation_reason String?
  cancelled_by      String?   @db.Uuid
  cancelled_at      DateTime? @db.Timestamptz(6)
  
  // Metadata
  created_by        String    @db.Uuid
  updated_by        String?   @db.Uuid
  created_at        DateTime  @default(now()) @db.Timestamptz(6)
  updated_at        DateTime  @default(now()) @db.Timestamptz(6)
  
  // Relations
  clinic            Clinic    @relation(fields: [clinic_id], references: [id])
  patient           Patient   @relation(fields: [patient_id], references: [id])
  provider          Profile   @relation("ProviderAppointments", fields: [provider_id], references: [id])
  created_by_profile Profile  @relation("AppointmentCreatedBy", fields: [created_by], references: [id])
  
  // Medical records related to this appointment
  medical_records   MedicalRecord[]
  prescriptions     Prescription[]
  
  @@map("appointments")
}

/// Patient medical records and history
model MedicalRecord {
  id                String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  patient_id        String      @db.Uuid
  clinic_id         String      @db.Uuid
  appointment_id    String?     @db.Uuid
  provider_id       String      @db.Uuid
  
  // Medical content
  record_type       String      // consultation, exam_result, procedure, diagnosis
  title            String
  description      String?
  diagnosis_codes   String[]    // ICD-10 codes
  symptoms         String[]
  treatment        String?
  recommendations  String?
  
  // Clinical data
  vital_signs      Json?       // { "blood_pressure": "120/80", "temperature": "36.5", etc. }
  exam_results     Json?       // Lab results, imaging results, etc.
  
  // LGPD compliance
  sensitive_data   Boolean     @default(true)
  data_retention_date DateTime? @db.Timestamptz(6)
  
  // Metadata
  record_date      DateTime    @default(now()) @db.Timestamptz(6)
  created_by       String      @db.Uuid
  created_at       DateTime    @default(now()) @db.Timestamptz(6)
  updated_at       DateTime    @default(now()) @db.Timestamptz(6)
  
  // Relations
  patient          Patient     @relation(fields: [patient_id], references: [id])
  clinic           Clinic      @relation(fields: [clinic_id], references: [id])
  appointment      Appointment? @relation(fields: [appointment_id], references: [id])
  provider         Profile     @relation("ProviderMedicalRecords", fields: [provider_id], references: [id])
  created_by_profile Profile   @relation("MedicalRecordCreatedBy", fields: [created_by], references: [id])
  
  @@map("medical_records")
}

/// Prescription and medication management
model Prescription {
  id                    String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  patient_id            String      @db.Uuid
  clinic_id             String      @db.Uuid
  appointment_id        String?     @db.Uuid
  prescriber_id         String      @db.Uuid
  
  // Medication details
  medication_name       String
  dosage               String      // "500mg", "10ml", etc.
  frequency            String      // "2x daily", "Every 8 hours", etc.
  duration             String      // "7 days", "Until symptoms resolve", etc.
  quantity             String      // "30 tablets", "1 bottle", etc.
  
  // Instructions and warnings
  instructions         String?
  warnings             String?
  contraindications    String?
  
  // Prescription metadata
  status               String      @default("active") // active, completed, cancelled, expired
  prescribed_date      DateTime    @default(now()) @db.Timestamptz(6)
  start_date           DateTime?   @db.Timestamptz(6)
  end_date             DateTime?   @db.Timestamptz(6)
  
  // Digital signature and compliance
  digital_signature    String?     // CFM compliance
  cfm_registration     String?     // Medical professional registration
  pharmacy_dispensed   Boolean     @default(false)
  dispensed_at         DateTime?   @db.Timestamptz(6)
  dispensed_by         String?     // Pharmacy information
  
  // ANVISA compliance
  anvisa_code          String?     // ANVISA medication code
  controlled_substance Boolean     @default(false)
  
  // Metadata
  created_by           String      @db.Uuid
  updated_by           String?     @db.Uuid
  created_at           DateTime    @default(now()) @db.Timestamptz(6)
  updated_at           DateTime    @default(now()) @db.Timestamptz(6)
  
  // Relations
  patient              Patient     @relation(fields: [patient_id], references: [id])
  clinic               Clinic      @relation(fields: [clinic_id], references: [id])
  appointment          Appointment? @relation(fields: [appointment_id], references: [id])
  prescriber           Profile     @relation("PrescriberPrescriptions", fields: [prescriber_id], references: [id])
  created_by_profile   Profile     @relation("PrescriptionCreatedBy", fields: [created_by], references: [id])
  
  @@map("prescriptions")
}

/// Audit log for LGPD and ANVISA compliance
model AuditLog {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  
  // User and tenant context
  user_id           String    @db.Uuid
  clinic_id         String    @db.Uuid
  
  // Action details
  action            String    // CREATE, READ, UPDATE, DELETE, EXPORT, etc.
  resource_type     String    // patient, appointment, prescription, etc.
  resource_id       String?   @db.Uuid
  
  // Request metadata
  ip_address        String?
  user_agent        String?
  endpoint          String?
  method            String?   // GET, POST, PUT, DELETE
  
  // Data changes (for UPDATE actions)
  old_values        Json?
  new_values        Json?
  
  // Compliance context
  lgpd_lawful_basis String?   // consent, contract, legal_obligation, etc.
  anvisa_category   String?   // clinical_data, prescription, etc.
  cfm_regulation    String?   // CFM regulation reference
  
  // Metadata
  timestamp         DateTime  @default(now()) @db.Timestamptz(6)
  
  // Relations
  user              Profile   @relation("UserAuditLogs", fields: [user_id], references: [id])
  clinic            Clinic    @relation(fields: [clinic_id], references: [id])
  
  @@map("audit_logs")
}