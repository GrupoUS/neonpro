// Minimal Prisma schema for Vercel testing

generator client {
  provider = "prisma-client-js"
  binaryTargets = ["rhel-openssl-1.0.x", "linux-musl"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Simple test model
model TestTable {
  id        Int      @id @default(autoincrement())
  name      String
  createdAt DateTime @default(now())
}