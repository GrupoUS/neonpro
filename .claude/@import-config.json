{
  "$schema": "https://claude.ai/schemas/@import-config.json",
  "version": "1.0.0",
  "name": "@import-intelligent-system",
  "description": "Sistema de referência inteligente @import para carregamento condicional de módulos baseado em complexidade e triggers",
  
  "efficiency_targets": {
    "context_optimization": "85%+",
    "token_reduction": "40%+",
    "load_time_improvement": "60%+",
    "trigger_accuracy": "95%+"
  },
  
  "complexity_levels": {
    "L1_basic": {
      "range": [1, 2],
      "description": "Operações simples e queries básicas",
      "load_strategy": "minimal",
      "required_modules": ["base"],
      "optional_modules": [],
      "examples": ["basic file operations", "simple queries", "quick lookups"]
    },
    "L2_moderate": {
      "range": [3, 4],
      "description": "Implementações técnicas requerendo documentação",
      "load_strategy": "selective",
      "required_modules": ["base", "mcp-authority"],
      "optional_modules": ["domain-healthcare"],
      "examples": ["MCP operations", "technical implementations", "file management"]
    },
    "L3_complex": {
      "range": [5, 6],
      "description": "Implementações multi-step requerendo pesquisa",
      "load_strategy": "comprehensive",
      "required_modules": ["base", "mcp-authority", "system-control"],
      "optional_modules": ["domain-healthcare", "performance-engine"],
      "examples": ["architecture decisions", "complex integrations", "system design"]
    },
    "L4_enterprise": {
      "range": [7, 10],
      "description": "Implementações enterprise com validação completa",
      "load_strategy": "full",
      "required_modules": ["base", "mcp-authority", "system-control", "domain-healthcare", "performance-engine"],
      "optional_modules": [],
      "examples": ["enterprise architecture", "critical system migration", "compliance implementation"]
    }
  },
  
  "trigger_system": {
    "bilingual_support": true,
    "languages": ["português", "english"],
    "trigger_categories": {
      "domain_specialization": {
        "português": ["domínio", "setor", "indústria", "negócio", "compliance", "especialização", "vertical", "regulamentação"],
        "english": ["domain", "sector", "industry", "business", "compliance", "specialization", "vertical", "regulation"],
        "modules": ["domain-specialization"],
        "complexity_min": 2
      },
      "mcp_operations": {
        "português": ["mcp", "desktop-commander", "arquivo", "terminal", "implementar", "criar", "desenvolver", "construir"],
        "english": ["mcp", "desktop-commander", "file", "terminal", "implement", "create", "develop", "build"],
        "modules": ["mcp-authority"],
        "complexity_min": 2
      },
      "performance": {
        "português": ["performance", "otimizar", "velocidade", "latência", "benchmark", "acelerar", "melhorar"],
        "english": ["performance", "optimize", "speed", "latency", "benchmark", "accelerate", "improve"],
        "modules": ["performance-engine"],
        "complexity_min": 4
      },
      "system_architecture": {
        "português": ["sistema", "arquitetura", "vibecode", "autoridade", "controle", "orquestração"],
        "english": ["system", "architecture", "vibecode", "authority", "control", "orchestration"],
        "modules": ["system-control"],
        "complexity_min": 3
      },
      "quality_assurance": {
        "português": ["qualidade", "testes", "validação", "compliance", "segurança", "auditoria"],
        "english": ["quality", "testing", "validation", "compliance", "security", "audit"],
        "modules": ["system-control", "domain-specialization"],
        "complexity_min": 3
      }
    }
  },
  
  "modules": {
    "base": {
      "file": "CLAUDE.md",
      "path": "C:\\Users\\Mauri\\OneDrive\\GRUPOUS\\VSCODE\\neonpro\\CLAUDE.md",
      "description": "Configuração principal do projeto neonpro",
      "load_priority": 1,
      "always_load": true
    },
    "mcp-authority": {
      "file": "mcp-authority.md",
      "path": "C:\\Users\\Mauri\\OneDrive\\GRUPOUS\\VSCODE\\neonpro\\.claude\\core\\mcp-authority.md",
      "description": "MCP orchestration e intelligent routing",
      "load_priority": 2,
      "triggers": ["mcp", "desktop-commander", "file", "terminal", "implementar", "arquivo"],
      "complexity_threshold": 2
    },
    "system-control": {
      "file": "system-control.md", 
      "path": "C:\\Users\\Mauri\\OneDrive\\GRUPOUS\\VSCODE\\neonpro\\.claude\\core\\system-control.md",
      "description": "VIBECODE system authority e control",
      "load_priority": 3,
      "triggers": ["system", "architecture", "vibecode", "authority", "sistema", "arquitetura"],
      "complexity_threshold": 3
    },
    "domain-specialization": {
      "file": "domain-specialization.md",
      "path": "C:\\Users\\Mauri\\OneDrive\\GRUPOUS\\VSCODE\\neonpro\\.claude\\core\\domain-specialization.md", 
      "description": "Universal domain specialization framework",
      "load_priority": 4,
      "triggers": ["domain", "industry", "business", "domínio", "setor", "negócio", "specialization"],
      "complexity_threshold": 2
    },
    "performance-engine": {
      "file": "performance-engine.md",
      "path": "C:\\Users\\Mauri\\OneDrive\\GRUPOUS\\VSCODE\\neonpro\\.claude\\core\\performance-engine.md",
      "description": "Research-first performance optimization",
      "load_priority": 5,
      "triggers": ["performance", "optimize", "speed", "otimizar", "velocidade", "benchmark"],
      "complexity_threshold": 4
    }
  },
  
  "conditional_loading": {
    "strategy": "intelligent_routing",
    "evaluation_criteria": [
      "trigger_detection",
      "complexity_assessment", 
      "context_relevance",
      "token_optimization"
    ],
    "fallback_behavior": "load_base_only",
    "max_modules_per_session": 4,
    "cache_enabled": true,
    "cache_duration": "1h"
  },
  
  "optimization": {
    "context_window_management": true,
    "token_budget_tracking": true,
    "module_dependency_resolution": true,
    "smart_preloading": false,
    "compression_enabled": true
  },
  
  "validation": {
    "syntax_checking": true,
    "circular_dependency_detection": true,
    "module_availability_check": true,
    "trigger_coverage_analysis": true
  },
  
  "monitoring": {
    "usage_analytics": true,
    "performance_metrics": true,
    "efficiency_tracking": true,
    "error_reporting": true
  }
}