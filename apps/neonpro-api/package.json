{
  "name": "neonpro-healthcare-api",
  "version": "3.0.0",
  "description": "NeonPro Healthcare API with LGPD and ANVISA compliance",
  "main": "api/index.ts",
  "type": "module",
  "scripts": {
    "dev": "fastify start --log-level info --pretty-logs --address 0.0.0.0 --port 3000 src/server.ts",
    "start": "node dist/server.js",
    "build": "tsc && biome check --apply ./src",
    "build:vercel": "tsc --project tsconfig.json && biome check --apply ./src",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch --passWithNoTests",
    "test:coverage": "jest --coverage --passWithNoTests",
    "test:healthcare": "jest --testPathPattern=healthcare --passWithNoTests",
    "test:lgpd": "jest --testPathPattern=lgpd --passWithNoTests",
    "test:anvisa": "jest --testPathPattern=anvisa --passWithNoTests",
    "test:compliance": "npm run test:lgpd && npm run test:anvisa",
    "test:integration": "jest --testPathPattern=integration --passWithNoTests",
    "test:unit": "jest --testPathPattern=unit --passWithNoTests",
    "lint": "biome check ./src",
    "lint:fix": "biome check --apply ./src",
    "format": "biome format --write ./src",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist coverage",
    "vercel-build": "npm run build:vercel",
    "db:migrate": "supabase migration up",
    "db:migrate:test": "supabase migration up --db-url=$DATABASE_URL",
    "db:seed": "supabase seed",
    "generate:types": "supabase gen types typescript --project-id=$SUPABASE_PROJECT_ID > src/types/database.ts",
    "healthcare:validate": "node scripts/validate-healthcare-compliance.js",
    "bmad:validate": "node scripts/validate-bmad-methodology.js",
    "security:audit": "npm audit --audit-level moderate",
    "performance:test": "node scripts/performance-test.js"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/helmet": "^11.1.1",
    "@fastify/rate-limit": "^9.1.0",
    "@fastify/swagger": "^8.14.0",
    "@fastify/swagger-ui": "^2.0.0",
    "@supabase/supabase-js": "^2.39.3",
    "@vercel/node": "^3.0.21",
    "bullmq": "^4.15.4",
    "fastify": "^4.25.2",
    "ioredis": "^5.3.2",
    "pg": "^8.11.3",
    "pino": "^8.17.2",
    "prom-client": "^15.1.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@biomejs/biome": "1.6.0",
    "@types/jest": "^29.5.11",
    "@types/node": "^20.11.5",
    "@types/pg": "^8.10.9",
    "jest": "^29.7.0",
    "typescript": "^5.3.3",
    "ts-jest": "^29.1.1"
  },
  "engines": {
    "node": ">=18.17.0"
  },
  "keywords": [
    "healthcare",
    "api",
    "lgpd",
    "anvisa",
    "bmad",
    "fastify",
    "vercel",
    "brazilian-healthcare",
    "compliance"
  ],
  "author": "NeonPro Healthcare Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/neonpro/healthcare-api.git"
  },
  "homepage": "https://api.neonpro.health",
  "bugs": {
    "url": "https://github.com/neonpro/healthcare-api/issues"
  }
}