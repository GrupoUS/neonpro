{
  "name": "@neonpro/file-processing-edge",
  "version": "1.0.0", 
  "private": true,
  "type": "module",
  "description": "NeonPro Medical File Processing - Hono Edge Service with OCR & AI Analysis",
  "main": "dist/index.js",
  "scripts": {
    "dev": "wrangler dev src/index.ts",
    "build": "esbuild src/index.ts --bundle --outfile=dist/index.js --format=esm --platform=neutral --target=es2022",
    "deploy": "wrangler deploy",
    "start": "node dist/index.js",
    "test": "vitest",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "hono": "^4.0.0",
    "@hono/zod-validator": "^0.2.0",
    "zod": "^3.24.1",
    "@supabase/supabase-js": "^2.48.1",
    "pdf-parse": "^1.1.1",
    "sharp": "^0.33.5",
    "tesseract.js": "^5.0.4",
    "@tensorflow/tfjs": "^4.15.0",
    "mammoth": "^1.6.0",
    "csv-parser": "^3.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "typescript": "^5.7.3",
    "esbuild": "^0.20.0",
    "wrangler": "^3.28.0",
    "vitest": "^1.1.3",
    "@vitest/coverage-v8": "^1.1.3",
    "@cloudflare/workers-types": "^4.20240117.0"
  },
  "engines": {
    "node": ">=18.17.0"
  },
  "keywords": [
    "medical-documents",
    "ocr",
    "ai-analysis", 
    "edge-computing",
    "file-processing",
    "healthcare-compliance",
    "anvisa",
    "lgpd"
  ]
}