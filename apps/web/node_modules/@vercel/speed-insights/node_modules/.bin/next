#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")

case `uname` in
    *CYGWIN*|*MINGW*|*MSYS*)
        if command -v cygpath > /dev/null 2>&1; then
            basedir=`cygpath -w "$basedir"`
        fi
    ;;
esac

if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../../../../../../next@15.4.5_@babel+core@7.2_a55f1df9d3e20efa4afba03536dc909f/node_modules/next/dist/bin/next" "$@"
else
  exec node  "$basedir/../../../../../../next@15.4.5_@babel+core@7.2_a55f1df9d3e20efa4afba03536dc909f/node_modules/next/dist/bin/next" "$@"
fi
