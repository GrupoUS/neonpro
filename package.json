{
  "name": "neonpro-monorepo",
  "version": "2.0.0",
  "private": true,
  "description": "NeonPro - Sistema de Gestão para Clínicas de Estética (Monorepo)",
  "packageManager": "pnpm@8.15.0",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "type-check": "turbo type-check",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:debug": "playwright test --debug",
    "test:headed": "playwright test --headed",
    "test:report": "playwright show-report",
    "clean": "turbo clean",
    "dev:web": "turbo dev --filter=@neonpro/web",
    "build:web": "turbo build --filter=@neonpro/web",
    "prepare": "husky",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "format:biome": "biome format --write .",
    "lint:biome": "biome lint .",
    "lint:biome:fix": "biome lint --write .",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "ci": "biome ci ."
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.0",
    "@types/node": "^22.10.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.5",
    "prettier": "^3.6.2",
    "turbo": "^2.4.4",
    "typescript": "^5.7.2",
    "ultracite": "^5.1.5"
  },
  "engines": {
    "node": ">=18.17.0",
    "pnpm": ">=8.0.0"
  },
  "keywords": [
    "clinic-management",
    "healthcare",
    "monorepo",
    "nextjs",
    "supabase"
  ],
  "dependencies": {
    "@supabase/auth-helpers-nextjs": "^0.10.0",
    "@supabase/ssr": "^0.6.1",
    "@supabase/supabase-js": "^2.55.0",
    "dotenv": "^17.2.1"
  }
}
