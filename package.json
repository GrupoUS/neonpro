{
  "name": "my-v0-project",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "next build",
    "build:analyze": "ANALYZE=true next build",
    "lighthouse": "lighthouse http://localhost:3000 --output=json --output-path=./performance/lighthouse-report.json --chrome-flags=\"--headless\" --quiet",
    "performance:analyze": "node scripts/performance/bundle-analyzer.js",
    "dev": "next dev",
    "lint": "next lint",
    "start": "next start",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:unit": "jest --testPathPattern=__tests__",
    "test:hooks": "jest --testPathPattern=__tests__/hooks",
    "test:components": "jest --testPathPattern=__tests__/components",
    "test:api": "jest --testPathPattern=__tests__/api",
    "test:integration": "jest --testPathPattern=__tests__/integration",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:all": "npm run test && npm run test:e2e",
    "test:ci": "jest --coverage --watchAll=false --passWithNoTests",
    "type-check": "tsc --noEmit",
    "sentry:upload-sourcemaps": "sentry-cli sourcemaps upload --validate --log-level=info ./.next/static",
    "sentry:create-release": "sentry-cli releases new $npm_package_version",
    "sentry:finalize-release": "sentry-cli releases finalize $npm_package_version",
    "deploy": "npm run build && npm run sentry:create-release && npm run sentry:upload-sourcemaps && npm run sentry:finalize-release",
    "validate:supabase": "node scripts/validate-supabase-config.js",
    "validate:supabase:fix": "node scripts/validate-supabase-config.js --fix",
    "vibecode:health": "npm run validate:supabase && npm run type-check && npm run lint"
  },
