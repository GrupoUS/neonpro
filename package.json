{
	"name": "neonpro-monorepo",
	"version": "2.0.0",
	"private": true,
	"description": "NeonPro - Sistema de Gestão para Clínicas de Estética (Monorepo)",
	"packageManager": "pnpm@8.15.0",
	"scripts": {
		"dev": "turbo dev",
		"build": "turbo build",
		"lint": "turbo lint",
		"type-check": "turbo type-check",
		"test": "turbo test",
		"clean": "turbo clean",
		"dev:web": "turbo dev --filter=@neonpro/web",
		"build:web": "turbo build --filter=@neonpro/web",
		"prepare": "husky || true"
	},
	"devDependencies": {
		"@types/node": "^22.10.2",
		"husky": "^9.1.7",
		"turbo": "^2.4.4",
		"typescript": "^5.7.2"
	},
	"engines": {
		"node": ">=18.17.0",
		"pnpm": ">=8.0.0"
	},
	"keywords": [
		"clinic-management",
		"healthcare",
		"monorepo",
		"nextjs",
		"supabase"
	],
	"dependencies": {
		"@supabase/auth-helpers-nextjs": "^0.10.0",
		"@supabase/ssr": "^0.6.1",
		"@supabase/supabase-js": "^2.55.0",
		"@types/jest": "^30.0.0",
		"dotenv": "^17.2.1",
		"jest": "^30.0.5",
		"ts-jest": "^29.4.1"
	}
}
