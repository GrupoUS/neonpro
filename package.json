{
	"name": "neonpro-monorepo",
	"version": "2.0.0",
	"private": true,
	"description": "NeonPro - Sistema de Gestão para Clínicas de Estética (Monorepo)",
	"packageManager": "pnpm@8.15.0",
	"scripts": {
		"dev": "turbo dev",
		"build": "turbo build",
		"lint": "turbo lint",
		"type-check": "turbo type-check",
		"test": "turbo test",
		"clean": "turbo clean",
		"dev:web": "turbo dev --filter=@neonpro/web",
		"build:web": "turbo build --filter=@neonpro/web",
		"prepare": "husky || true"
	},
	"devDependencies": {
		"turbo": "^2.4.4",
		"typescript": "^5.7.2",
		"@types/node": "^22.10.2",
		"husky": "^9.1.7"
	},
	"engines": {
		"node": ">=18.17.0",
		"pnpm": ">=8.0.0"
	},
	"keywords": [
		"clinic-management",
		"healthcare",
		"monorepo",
		"nextjs",
		"supabase"
	]
}
