# Configuração de Produção - NeonPro
# Copie este arquivo para .env.production e configure com os valores reais

# Supabase Configuration (Produção)
NEXT_PUBLIC_SUPABASE_URL=https://gfkskrkbnawkuppazkpt.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_production_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_production_supabase_service_role_key

# App Configuration (Produção)
NEXT_PUBLIC_APP_URL=https://your-domain.com
NEXT_PUBLIC_APP_NAME=NeonPro
NODE_ENV=production

# WhatsApp Business API (Produção)
WHATSAPP_API_KEY=your_production_whatsapp_api_key
WHATSAPP_PHONE_NUMBER=your_production_whatsapp_phone_number_id
WHATSAPP_VERIFY_TOKEN=your_production_webhook_verify_token
WHATSAPP_WEBHOOK_SECRET=your_production_webhook_secret

# Email Service (Produção)
EMAIL_SERVICE_API_KEY=your_production_email_service_api_key
EMAIL_FROM=noreply@your-domain.com

# Analytics (Produção)
NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=your_production_google_analytics_id

# Sentry (Produção)
SENTRY_DSN=your_production_sentry_dsn
SENTRY_ORG=your_sentry_org
SENTRY_PROJECT=neonpro-production

# Vercel Configuration
NEXT_PUBLIC_VERCEL_URL=your-app.vercel.app
NEXT_PUBLIC_PRODUCTION_URL=https://your-domain.com

# Security
NEXTAUTH_SECRET=your_nextauth_secret_key_for_production
NEXTAUTH_URL=https://your-domain.com
