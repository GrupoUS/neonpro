/**
 * Advanced Subscription Error Types
 *
 * Comprehensive error type system for subscription middleware with:
 * - Structured error classification
 * - Recovery strategy hints
 * - Monitoring metadata
 * - User-friendly messaging
 *
 * @author NeonPro Development Team
 * @version 2.0.0 - Error Handling Enhanced
 */

import type { SubscriptionStatus } from "../lib/subscription-status";

// Base error severity levels
export enum ErrorSeverity {
  LOW = "low", // Minor issues, system continues
  MEDIUM = "medium", // Important issues, some degradation
  HIGH = "high", // Serious issues, major degradation
  CRITICAL = "critical", // System-breaking issues
}

// Error categories for better classification
export enum ErrorCategory {
  AUTHENTICATION = "authentication",
  AUTHORIZATION = "authorization",
  NETWORK = "network",
  DATABASE = "database",
  CACHE = "cache",
  VALIDATION = "validation",
  EXTERNAL_SERVICE = "external_service",
  RATE_LIMIT = "rate_limit",
  TIMEOUT = "timeout",
  UNKNOWN = "unknown",
}

// Recovery strategies
export enum RecoveryStrategy {
  RETRY = "retry",
  FALLBACK = "fallback",
  CIRCUIT_BREAK = "circuit_break",
  GRACEFUL_DEGRADE = "graceful_degrade",
  USER_INTERVENTION = "user_intervention",
  SYSTEM_RESTART = "system_restart",
}

// Base subscription error interface
export interface SubscriptionError extends Error {
  code: string;
  severity: ErrorSeverity;
  category: ErrorCategory;
  recoveryStrategy: RecoveryStrategy;
  metadata: Record<string, any>;
  timestamp: Date;
  userId?: string;
  requestId?: string;
  userMessage: string;
  technicalMessage: string;
  retryable: boolean;
  shouldLog: boolean;
  shouldAlert: boolean;
}

// Specific error types
export class SubscriptionAuthError extends Error implements SubscriptionError {
  code = "SUB_AUTH_ERROR";
  severity = ErrorSeverity.HIGH;
  category = ErrorCategory.AUTHENTICATION;
  recoveryStrategy = RecoveryStrategy.USER_INTERVENTION;
  metadata: Record<string, any> = {};
  timestamp = new Date();
  userId?: string;
  requestId?: string;
  userMessage = "Authentication required. Please log in to continue.";
  technicalMessage: string;
  retryable = false;
  shouldLog = true;
  shouldAlert = false;

  constructor(technicalMessage: string, metadata?: Record<string, any>) {
    super(technicalMessage);
    this.name = "SubscriptionAuthError";
    this.technicalMessage = technicalMessage;
    this.metadata = metadata || {};
  }
}

