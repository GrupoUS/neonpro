// Error context for enriched error reporting
export interface ErrorContext {
  userId?: string;
  sessionId?: string;
  requestId?: string;
  userAgent?: string;
  ipAddress?: string;
  route?: string;
  method?: string;
  subscriptionStatus?: SubscriptionStatus;
  cacheStatus?: "hit" | "miss" | "error";
  retryAttempt?: number;
  totalRetries?: number;
  startTime?: Date;
  duration?: number;
  additionalContext?: Record<string, any>;
}

// Error factory for creating typed errors
export class SubscriptionErrorFactory {
  static createError(
    type:
      | "auth"
      | "validation"
      | "network"
      | "database"
      | "cache"
      | "rate_limit"
      | "timeout"
      | "external_service",
    technicalMessage: string,
    context?: ErrorContext,
  ): SubscriptionError {
    const metadata = context ? { ...context } : {};

    switch (type) {
      case "auth":
        return new SubscriptionAuthError(technicalMessage, metadata);
      case "validation":
        return new SubscriptionValidationError(technicalMessage, metadata);
      case "network":
        return new SubscriptionNetworkError(technicalMessage, metadata);
      case "database":
        return new SubscriptionDatabaseError(technicalMessage, metadata);
      case "cache":
        return new SubscriptionCacheError(technicalMessage, metadata);
      case "rate_limit":
        return new SubscriptionRateLimitError(technicalMessage, metadata);
      case "timeout":
        return new SubscriptionTimeoutError(technicalMessage, metadata);
      case "external_service":
        return new SubscriptionExternalServiceError(technicalMessage, metadata);
      default:
        // Default to validation error for unknown types
        return new SubscriptionValidationError(technicalMessage, metadata);
    }
  }

  static enrichError(error: SubscriptionError, context: ErrorContext): SubscriptionError {
    error.userId = context.userId;
    error.requestId = context.requestId;
    error.metadata = { ...error.metadata, ...context };
    return error;
  }
}

// Error statistics for monitoring
export interface ErrorStats {
  total: number;
  byCategory: Record<ErrorCategory, number>;
  bySeverity: Record<ErrorSeverity, number>;
  byCode: Record<string, number>;
  timeWindow: {
    start: Date;
    end: Date;
  };
  trends: {
    increasing: boolean;
    rate: number;
    pattern: "normal" | "spike" | "sustained";
  };
}

