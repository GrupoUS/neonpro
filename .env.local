# NEONPRO Environment Variables - Phase 7 AI Integration
# Generated by VIBECODE SYSTEM V4.0 - AI Integration Setup
# Copy this file to .env.local and fill in your actual values

# ===== DATABASE =====
# Supabase Postgres Database URL
DATABASE_URL="postgresql://postgres:[password]@db.[project].supabase.co:5432/postgres"

# ===== SUPABASE =====
# Supabase Project Configuration
NEXT_PUBLIC_SUPABASE_URL="https://[project].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-supabase-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"

# ===== AI INTEGRATION - PHASE 7 =====
# OpenAI API Configuration
OPENAI_API_KEY="sk-your-openai-api-key-here"
OPENAI_ORGANIZATION_ID="org-your-organization-id"

# Vercel AI SDK Configuration
AI_MODEL="gpt-4o"
AI_MAX_TOKENS="3000"
AI_TEMPERATURE="0.6"

# AI Rate Limiting
AI_REQUESTS_PER_MINUTE="60"
AI_REQUESTS_PER_HOUR="1000"
AI_REQUESTS_PER_DAY="10000"
AI_DAILY_BUDGET="100"
AI_MONTHLY_BUDGET="2000"

# ===== AUTHENTICATION =====
# NextAuth.js Configuration
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-nextauth-secret"

# ===== EXTERNAL SERVICES =====
# Email Service (Resend)
RESEND_API_KEY="re_your-resend-api-key"

# File Storage
NEXT_PUBLIC_STORAGE_BUCKET="neonpro-storage"

# ===== DEVELOPMENT =====
# Development Environment
NODE_ENV="development"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ===== ANALYTICS =====
# Optional: Analytics Configuration
NEXT_PUBLIC_ANALYTICS_ID="your-analytics-id"

# ===== SECURITY =====
# CORS Configuration
ALLOWED_ORIGINS="http://localhost:3000,https://neonpro.vercel.app"

# Rate Limiting
UPSTASH_REDIS_REST_URL="your-upstash-redis-url"
UPSTASH_REDIS_REST_TOKEN="your-upstash-redis-token"
