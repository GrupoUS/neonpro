#!/usr/bin/env sh

echo "🚀 NEONPRO Pre-commit Quality Validation"
echo "========================================"

# Run lint-staged for staged files (includes Ultracite formatting)
echo "🔍 Running lint-staged with Ultracite..."
npx lint-staged

# Check exit code
if [ $? -ne 0 ]; then
    echo "❌ Lint-staged failed. Please fix the issues and try again."
    exit 1
fi

# Run type checking
echo "🏗️  Running type check..."
pnpm run type-check

if [ $? -ne 0 ]; then
    echo "❌ Type check failed. Please fix TypeScript errors and try again."
    exit 1
fi

# Run unit tests (without coverage for speed)
echo "🧪 Running unit tests..."
pnpm run test:unit

if [ $? -ne 0 ]; then
    echo "❌ Unit tests failed. Please fix failing tests and try again."
    exit 1
fi

echo "✅ All pre-commit validations passed!"
echo "🎯 Code quality standards maintained with Ultracite + lint-staged"